# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Developer-specific settings (contains DEVELOPMENT_TEAM etc.)
ios/DeveloperSettings.xcconfig

# Auto-generated plugin registrants (regenerated by flutter pub get)
linux/flutter/generated_plugin_registrant.*
linux/flutter/generated_plugins.cmake
macos/Flutter/GeneratedPluginRegistrant.swift
windows/flutter/generated_plugin_registrant.*
windows/flutter/generated_plugins.cmake

